# ── MemeGuard Environment Variables ──

# LLM Configuration
MEMEGUARD_TRIAGE_MODEL=gemini-2.5-flash
MEMEGUARD_INVESTIGATION_MODEL=claude-sonnet-4-6
GOOGLE_GENERATIVE_AI_API_KEY=         # For Gemini Flash (Phase 2)
ANTHROPIC_API_KEY=                     # For Claude (Phase 3)

# BSC Configuration
BSC_RPC_URL=https://bsc-dataseed1.binance.org
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
BSCSCAN_API_KEY=                       # Etherscan API key (https://etherscan.io/apis — works for BSC via V2)

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Engine
MEMEGUARD_PORT=8004
MEMEGUARD_TRIAGE_RISK_THRESHOLD=3
MEMEGUARD_MAX_AGENT_TURNS=20

# ── Production / Deployment ──

# Engine: set to allow CORS from your frontend domain
FRONTEND_URL=https://memeguard.vercel.app

# Frontend: set to your deployed engine URL (used at build time)
NEXT_PUBLIC_ENGINE_URL=http://localhost:8004
